# ─────────────────────────────────────────────────────────────────────────────
# Unusual Flow Radar — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App mode ─────────────────────────────────────────────────────────────────
# Set both to "true" to run entirely offline with synthetic data.
# No API keys, database, or Redis needed in mock mode.
MOCK_MODE=true
NEXT_PUBLIC_MOCK_MODE=true

# ── Polygon.io ────────────────────────────────────────────────────────────────
# Required for live data. Get a key at https://polygon.io
# Starter plan: delayed data via REST.
# Advanced plan: real-time WebSocket feed for options trades.
POLYGON_API_KEY=your_polygon_api_key_here

# WebSocket endpoint (default shown — override only if using a proxy).
POLYGON_WS_URL=wss://socket.polygon.io/options

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Prisma ORM. Run `npx prisma db push` after setting this.
# Local:  postgresql://postgres:password@localhost:5432/unusual_flow_radar
# Neon:   postgresql://USER:PASSWORD@HOST.neon.tech/unusual_flow_radar?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/unusual_flow_radar

# ── Redis ─────────────────────────────────────────────────────────────────────
# Intraday rolling state, dedup store, and signal cache.
# Local:    redis://localhost:6379
# Upstash:  rediss://default:TOKEN@HOST:PORT
REDIS_URL=redis://localhost:6379

# Optional: separate Redis connection for BullMQ worker queues.
# If omitted, REDIS_URL is used for both.
REDIS_QUEUE_URL=redis://localhost:6379

# ── Detection thresholds ──────────────────────────────────────────────────────
# These are the server-side defaults. Individual users can override in Settings.
MIN_SIGNAL_NOTIONAL=50000
MIN_SIGNAL_CONTRACTS=100
MAX_DTE=90
MIN_PUBLISH_SCORE=55

# ── Worker concurrency ────────────────────────────────────────────────────────
TRADE_INGESTION_CONCURRENCY=4
SIGNAL_PROCESSOR_CONCURRENCY=2

# ── BullMQ ────────────────────────────────────────────────────────────────────
# Maximum retry attempts before a job is moved to the failed queue.
BULLMQ_MAX_RETRIES=3

# ── External data enrichment (optional) ──────────────────────────────────────
# Earnings calendar (Polygon /v3/reference/financials or Quandl)
EARNINGS_API_KEY=
# Macro events (FRED, Trading Economics)
MACRO_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
# debug | info | warn | error  (default: info in production)
LOG_LEVEL=info

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=https://YOUR_KEY@o0.ingest.sentry.io/PROJECT

# ── App URL ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3001
NODE_ENV=development
